NODE_ENV=development
PORT=4000
MONGODB_URI=mongodb://127.0.0.1:27017/hersentinel
STORAGE_PROVIDER=local
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=hersentinel/evidence
ACCESS_TOKEN_SECRET=replace_with_long_random_access_secret
REFRESH_TOKEN_SECRET=replace_with_long_random_refresh_secret
ACCESS_TOKEN_EXPIRES_IN=1h
REFRESH_TOKEN_EXPIRES_IN=7d
CLIENT_ORIGIN=http://localhost:8081
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
